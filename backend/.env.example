# TCS SmartOps Platform — Environment Configuration
# Copy this to .env and fill in your values

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-very-long-random-string-in-production-min-64-chars
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
RELOAD=true
WORKERS=1

# ── Database (when you switch from in-memory to real DB) ─────────────────────
# DATABASE_URL=postgresql://user:password@localhost:5432/smartops
# MONGODB_URL=mongodb://localhost:27017/smartops

# ── CORS ──────────────────────────────────────────────────────────────────────
# In production replace * with your actual domain
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500,http://127.0.0.1:5500

# ── AI Agent Intervals ────────────────────────────────────────────────────────
AGENT_BROADCAST_INTERVAL_SECONDS=12

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
